{
  "id": null,
  "uid": "dns-analytics",
  "title": "DNS Analytics",
  "tags": ["homelab", "dns", "technitium"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "type": "row",
      "title": "DNS Server Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Server Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_status{server=\"technitium\"}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Online", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Offline", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "type": "stat",
      "title": "Active Clients",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_client_count{server=\"technitium\"}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Zones",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_zone_count{server=\"technitium\"}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Cached Entries",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_cached_entry_count{server=\"technitium\"}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Blocked Zones",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_blocked_zone_count{server=\"technitium\"}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Update Available",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_update_available{server=\"technitium\"}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Up to date", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "Update available", "color": "yellow" } } },
            { "type": "value", "options": { "-1": { "text": "Unknown", "color": "gray" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "type": "row",
      "title": "Query Volume",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Queries by Protocol",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_query_protocol_count{server=\"technitium\"}",
        "legendFormat": "{{protocol}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 1, "drawStyle": "line", "showPoints": "never", "stacking": { "mode": "normal" } }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "type": "piechart",
      "title": "Protocol Distribution",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_query_protocol_count{server=\"technitium\"} > 0",
        "legendFormat": "{{protocol}}",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["percent"] }, "pieType": "donut" }
    },
    {
      "type": "piechart",
      "title": "Record Type Distribution",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_record_type_count{server=\"technitium\"} > 0",
        "legendFormat": "{{record_type}}",
        "refId": "A"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["percent"] }, "pieType": "donut" }
    },
    {
      "type": "row",
      "title": "Record Types",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Queries by Record Type",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_record_type_count{server=\"technitium\"}",
        "legendFormat": "{{record_type}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 1, "drawStyle": "line", "showPoints": "never" }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] } }
    },
    {
      "type": "row",
      "title": "Resolution & Results",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Request Results",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_request_result_count{server=\"technitium\"}",
        "legendFormat": "{{result}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15, "lineWidth": 1, "drawStyle": "line", "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "no_error" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "nx_domain" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "server_failure" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "refused" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Resolve Mode",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_resolve_mode_count{server=\"technitium\"}",
        "legendFormat": "{{result}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15, "lineWidth": 1, "drawStyle": "line", "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "cached" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "recursive" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "authoritative" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "blocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "dropped" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "type": "row",
      "title": "Cache & Blocking",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Cache Size",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_cached_entry_count{server=\"technitium\"}",
        "legendFormat": "Cached entries",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 1, "drawStyle": "line", "showPoints": "never", "gradientMode": "scheme" },
          "color": { "mode": "continuous-greens" }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Active Clients",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_client_count{server=\"technitium\"}",
        "legendFormat": "Clients",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 1, "drawStyle": "line", "showPoints": "never", "gradientMode": "scheme" },
          "color": { "mode": "continuous-blues" }
        }
      }
    },
    {
      "type": "bargauge",
      "title": "Zone Breakdown",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "technitium_dns_zone_count{server=\"technitium\"}", "legendFormat": "Total zones", "refId": "A" },
        { "expr": "technitium_dns_blocked_zone_count{server=\"technitium\"}", "legendFormat": "Blocked zones", "refId": "B" },
        { "expr": "technitium_dns_allowed_zone_count{server=\"technitium\"}", "legendFormat": "Allowed zones", "refId": "C" },
        { "expr": "technitium_dns_block_list_zone_count{server=\"technitium\"}", "legendFormat": "Block list zones", "refId": "D" },
        { "expr": "technitium_dns_allow_list_zone_count{server=\"technitium\"}", "legendFormat": "Allow list zones", "refId": "E" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Blocked zones" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Block list zones" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "type": "stat",
      "title": "Cache Hit Rate",
      "description": "Percentage of queries resolved from cache vs total resolved queries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_resolve_mode_count{server=\"technitium\",result=\"cached\"} / (technitium_dns_resolve_mode_count{server=\"technitium\",result=\"cached\"} + technitium_dns_resolve_mode_count{server=\"technitium\",result=\"recursive\"} + technitium_dns_resolve_mode_count{server=\"technitium\",result=\"authoritative\"}) * 100",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "value_and_name" }
    },
    {
      "type": "row",
      "title": "Top Domains",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 },
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Top Queried Domains",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "topk(20, technitium_dns_top_domain_hits{server=\"technitium\"})",
        "legendFormat": "{{domain}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "type": "bargauge",
      "title": "Top Blocked Domains",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "topk(20, technitium_dns_top_blocked_domain_hits{server=\"technitium\"})",
        "legendFormat": "{{domain}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "type": "row",
      "title": "Top Clients",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 58 },
      "collapsed": false
    },
    {
      "type": "bargauge",
      "title": "Top Clients by Query Count",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 59 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "topk(20, technitium_dns_top_client_hits{server=\"technitium\"})",
        "legendFormat": "{{client_name}} ({{client_ip}})",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "type": "row",
      "title": "Extended Query Stats",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 69 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Query Categories",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 70 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_queries_window{server=\"technitium\",category!=\"all\"}",
        "legendFormat": "{{category}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15, "lineWidth": 1, "drawStyle": "line", "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "no_error" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "cached" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "blocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "nxdomain" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "dropped" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } }
    },
    {
      "type": "piechart",
      "title": "Query Category Breakdown",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 70 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dns_queries_window{server=\"technitium\",category=~\"no_error|nxdomain|servfail|refused|blocked|dropped\"} > 0",
        "legendFormat": "{{category}}",
        "refId": "A"
      }],
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "no_error" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "blocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "nxdomain" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "table", "placement": "right", "calcs": ["percent"] }, "pieType": "donut" }
    },
    {
      "type": "row",
      "title": "Zones & DHCP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 78 },
      "collapsed": false
    },
    {
      "type": "table",
      "title": "Zone Inventory",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 79 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_zone_info{server=\"technitium\"}",
        "format": "table",
        "instant": true,
        "refId": "A"
      }],
      "transformations": [{
        "id": "organize",
        "options": {
          "excludeByName": { "Time": true, "__name__": true, "server": true, "instance": true, "job": true, "Value": true },
          "renameByName": { "zone": "Zone", "type": "Type", "disabled": "Disabled", "internal": "Internal", "serial": "Serial" }
        }
      }]
    },
    {
      "type": "bargauge",
      "title": "DHCP Leases",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 79 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{
        "expr": "technitium_dhcp_leases_total{server=\"technitium\"}",
        "legendFormat": "{{scope}} ({{type}})",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
