        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "ifNumber{instance=\"192.168.1.1\"}",
          "refId": "A"
