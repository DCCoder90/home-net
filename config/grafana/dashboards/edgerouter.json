    {
      "type": "table",
      "title": "Interface Status",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "expr": "ifOperStatus{instance=\"192.168.1.1\"}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "ifIndex": true,
              "instance": true
            },
            "renameByName": {
              "ifDescr": "Interface",
              "ifAlias": "Alias",
              "Value": "Status"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "Up",
                  "color": "green"
                },
                "2": {
                  "text": "Down",
                  "color": "red"
                }
              }
            }
          ],
          "custom": {
            "displayMode": "color-text"
          }
        }
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      }
    },
